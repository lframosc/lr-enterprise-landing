<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <title>Servicios Profesionales de Documentos - Luis Ramos - Avon, Indiana</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="stylesheet" href="style.css">
</head>

<body>

  <div class="page">
    <div class="left">

      <!-- LOGO LR ENTERPRISE -->
      <div class="logo-box">
        <svg width="100" height="100" viewBox="0 0 380 200" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="grad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#1FAF5A"/>
              <stop offset="100%" stop-color="#0E6B36"/>
            </linearGradient>
          </defs>

          <!-- Hexágono -->
          <polygon
            points="100,10 170,55 170,135 100,180 30,135 30,55"
            stroke="url(#grad)"
            stroke-width="6"
            fill="rgba(31,175,90,0.08)"
          />

          <!-- Letras LR dentro del hexágono -->
          <text x="72" y="120" font-size="70" font-weight="700" fill="url(#grad)">LR</text>
        </svg>
      </div>

      <!-- Aquí sigue tu contenido -->
      <h1>Servicios Profesionales de Documentos</h1>
      <p>Avon, Indiana – Atención confiable, rápida y profesional.</p>

    </div>

    <div class="right">
      <!-- Aquí va tu formulario -->
      <h2>Contáctame</h2>

      <form action="#" method="POST" enctype="multipart/form-data">
        <div class="form-group">
          <label>Nombre completo</label>
          <input type="text" name="nombre" required>
        </div>

        <div class="form-group">
          <label>Correo electrónico</label>
          <input type="email" name="email" required>
        </div>

        <div class="form-group">
          <label>Mensaje</label>
          <textarea name="mensaje" rows="4" required></textarea>
        </div>

        <div class="form-group">
          <label>Subir documentos (opcional)</label>
          <input type="file" name="archivo">
        </div>

        <button class="btn btn-primary btn-submit" type="submit">Enviar</button>
      </form>
    </div>
  </div>

<footer class="footer">
  <div class="footer-content">

    <div class="footer-left">
      <h3>LR ENTERPRISE</h3>
      <p>Servicios Profesionales de Documentos</p>
      <p>Avon, Indiana • Atención a toda la comunidad latina</p>
    </div>

    <div class="footer-center">
      <p><strong>Teléfono:</strong> (317) 457-4119</p>
      <p><strong>Email:</strong> lframosc@gmail.com</p>

      <div class="social-icons">
        <a href="#" class="social facebook">Facebook</a>
        <a href="#" class="social instagram">Instagram</a>
        <a href="#" class="social whatsapp">WhatsApp</a>
      </div>
    </div>

    <div class="footer-right">
      <p>Resolviendo tus documentos con precisión y confianza.</p>
      <p class="small">© 2026 LR Enterprise. Todos los derechos reservados.</p>
    </div>

  </div>
</footer>

</body>
</html>



